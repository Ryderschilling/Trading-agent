# Copy this file to .env and fill these in from Alpaca
APCA_API_KEY_ID=your_key
APCA_API_SECRET_KEY=your_secret

# Server
PORT=3000

# Alpaca stream feed: iex is free/basic plan. sip is paid.
ALPACA_FEED=iex

# Strategy
TIMEFRAME_MINUTES=5
RETEST_TOLERANCE_PCT=0.001
STRUCTURE_WINDOW=3
RS_WINDOW_BARS_5M=3

# Outcome tracking
TRACK_WINDOW_MINUTES=60

# Execution (paper trading)
# Set ALPACA_BASE_URL to paper endpoint. Switch to https://api.alpaca.markets for live.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Set to true to enable automatic options order placement
EXECUTION_ENABLED=false
# Fraction of account equity to risk per trade (2% = 0.02)
RISK_PCT_PER_TRADE=0.02
# Max number of new positions per trading day
MAX_TRADES_PER_DAY=5
# Stop trading for the day after losing this fraction of equity (5% = 0.05)
DAILY_LOSS_LIMIT_PCT=0.05